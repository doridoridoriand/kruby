#!/usr/bin/env bash
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

if [[ "${KRUBY_SKIP_HANDOFF_HOOK:-0}" != "1" ]]; then
  scripts/hooks/generate-handoff-report
fi

if command -v pre-commit >/dev/null 2>&1 && [[ -f .pre-commit-config.yaml ]]; then
  exec pre-commit run --hook-stage pre-commit
fi

files=()
while IFS= read -r file; do
  [[ -n "$file" ]] || continue
  files+=("$file")
done < <(git diff --cached --name-only --diff-filter=ACMR)

if [[ "${#files[@]}" -eq 0 ]]; then
  exit 0
fi

exec scripts/hooks/check-no-absolute-paths.sh "${files[@]}"
